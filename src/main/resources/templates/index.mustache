<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{csrfToken}}">
    <title>Spring AI Ops</title>
    <link rel="stylesheet" href="/style/aiops.css">
    <link rel="stylesheet" href="/webjars/highlightjs/11.10.0/styles/atom-one-dark.min.css" />
	<script src="/webjars/highlightjs/11.10.0/highlight.min.js"></script>
    <script src="/webjars/sockjs-client/1.5.1/sockjs.min.js"></script>
    <script src="/webjars/stomp-websocket/2.3.4/stomp.min.js"></script>
</head>
<body>

<!-- Server-rendered state exposed to JS -->
<script>
const LLM_CONFIGURED      = {{#configured}}true{{/configured}}{{^configured}}false{{/configured}};
const CURRENT_LLM         = '{{currentLlm}}';
const LLM_SELECT_PROVIDER = {{#selectProvider}}true{{/selectProvider}}{{^selectProvider}}false{{/selectProvider}};
const GIT_REMOTE_PROVIDERS = [{{#gitRemoteProviders}}{"name":"{{name}}","apiUrl":"{{apiUrl}}","domain":"{{domain}}"},{{/gitRemoteProviders}}];
const OBSERVABILITY_PROVIDERS = [{{#observabilityProviders}}{"name":"{{name}}","displayName":"{{displayName}}","apiUrl":"{{apiUrl}}"},{{/observabilityProviders}}];
</script>

<!-- ── Navbar ── -->
<nav class="navbar">
    <div class="navbar-brand">
        Spring AI Ops
    </div>
    <span class="navbar-subtitle">AI-Powered Observability & Code Intelligence</span>
</nav>

<!-- ══ Modal 1: LLM Setup ══ -->
<div id="llm-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            LLM Configuration
            <button id="llm-modal-close" class="modal-close-btn" onclick="closeLlmModal()" style="display:none;">&#10005;</button>
        </div>
        <div class="modal-body">
            <p class="modal-desc" id="llm-modal-desc">
                Select your LLM provider and enter an API key to get started.
            </p>
            <div class="radio-group">
                {{#llmProviders}}
                <div class="radio-option">
                    <input type="radio" name="llm-provider" id="llm-{{key}}" value="{{key}}">
                    <label for="llm-{{key}}">
                        <img src="/images/{{key}}.svg" class="provider-logo" alt="{{product}}">
                        <span style="text-transform:uppercase;">{{key}}</span>
                    </label>
                </div>
                {{/llmProviders}}
            </div>
            <div class="form-group">
                <label class="form-label" for="llm-api-key">API Key</label>
                <input type="password" id="llm-api-key" class="form-input"
                       placeholder="sk-..." autocomplete="off" />
            </div>
            <button class="btn-primary" id="llm-save-btn" onclick="saveLlmConfig()">
                Save &amp; Connect
            </button>
            <div class="alert alert-success" id="llm-alert-success">
                Connection successful! LLM is ready.
            </div>
            <div class="alert alert-warning" id="llm-alert-warning"></div>
            <div class="alert alert-error"   id="llm-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Select LLM Provider ══ -->
<div id="select-provider-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">Select LLM Provider</div>
        <div class="modal-body">
            <p class="modal-desc">
                API keys are pre-configured in application settings.<br>
                Please select the LLM provider you want to use.
            </p>
            <div class="radio-group">
                {{#llmProviders}}
                <div class="radio-option">
                    <input type="radio" name="select-provider" id="select-{{key}}" value="{{key}}">
                    <label for="select-{{key}}">
                        <img src="/images/{{key}}.svg" class="provider-logo" alt="{{product}}">
                        <span style="text-transform:uppercase;">{{key}}</span>
                    </label>
                </div>
                {{/llmProviders}}
            </div>
            <button class="btn-primary" id="select-provider-btn" onclick="submitSelectProvider()">Select</button>
            <div class="alert alert-error" id="select-provider-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Add Application ══ -->
<div id="add-app-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            Add Application
            <button class="modal-close-btn" onclick="closeAddAppModal()">&#10005;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label" for="add-app-input">Application Name</label>
                <input type="text" id="add-app-input" class="form-input"
                       placeholder="my-application" autocomplete="off" />
            </div>
            <div class="form-group">
                <label class="form-label" for="add-app-git-input">Git Repository URL <span style="color:#999;font-weight:400;">(optional, HTTP/HTTPS only)</span></label>
                <input type="text" id="add-app-git-input" class="form-input"
                       placeholder="https://github.com/owner/repo.git" autocomplete="off" />
            </div>
            <button class="btn-primary" id="add-app-save-btn" onclick="saveApp()">Add</button>
            <div class="alert alert-success" id="add-app-alert-success">Application registered successfully.</div>
            <div class="alert alert-error"   id="add-app-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Edit Application ══ -->
<div id="edit-app-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            Edit Application
            <button class="modal-close-btn" onclick="closeEditAppModal()">&#10005;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label" for="edit-app-name-input">Application Name</label>
                <input type="text" id="edit-app-name-input" class="form-input"
                       placeholder="my-application" autocomplete="off" />
            </div>
            <div class="form-group">
                <label class="form-label" for="edit-app-git-input">Git Repository URL <span style="color:#999;font-weight:400;">(optional, HTTP/HTTPS only)</span></label>
                <input type="text" id="edit-app-git-input" class="form-input"
                       placeholder="https://github.com/owner/repo.git" autocomplete="off" />
            </div>
            <button class="btn-primary" id="edit-app-save-btn" onclick="saveEditApp()">Save</button>
            <div class="alert alert-success" id="edit-app-alert-success">Application updated successfully.</div>
            <div class="alert alert-error"   id="edit-app-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Confirm Delete Application ══ -->
<div id="confirm-delete-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">Confirm Delete</div>
        <div class="modal-body">
            <p class="modal-desc" id="confirm-delete-desc">Are you sure you want to delete this application?</p>
            <div style="display:flex; gap:10px; margin-top:4px; align-items:center;">
                <button class="btn-primary" style="padding:5px 14px; font-size:0.85rem; font-weight:600;" onclick="confirmDeleteApp()">Yes</button>
                <button class="btn-secondary" style="margin-top:0;" onclick="closeConfirmDeleteModal()">Cancel</button>
            </div>
        </div>
    </div>
</div>

<!-- ══ Modal: GitHub Access Token ══ (legacy — kept for direct API access) -->

<!-- ══ Modal: Git Remote Configuration ══ -->
<div id="git-remote-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            Git Remote Configuration
            <button id="git-remote-modal-close" class="modal-close-btn" onclick="closeGitRemoteModal()" style="display:none;">&#10005;</button>
        </div>
        <div class="modal-body">
            <p class="modal-desc" id="git-remote-modal-desc">
                Select your Git provider and enter credentials to enable AI Code Review.
            </p>
            <div class="radio-group" id="git-remote-provider-group">
                <!-- dynamically populated from GIT_REMOTE_PROVIDERS -->
            </div>
            <div class="form-group">
                <label class="form-label" for="git-remote-url-input">Base API URL <span style="color:#999;font-weight:400;">(leave blank to use default)</span></label>
                <input type="text" id="git-remote-url-input" class="form-input" autocomplete="off" />
            </div>
            <div class="form-group">
                <label class="form-label" for="git-remote-token-input">Access Token</label>
                <input type="password" id="git-remote-token-input" class="form-input"
                       placeholder="" autocomplete="off" />
            </div>
            <button class="btn-primary" id="git-remote-save-btn" onclick="saveGitRemoteConfig()">Save &amp; Connect</button>
            <div class="alert alert-error" id="git-remote-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Run Code Risk Analysis ══ -->
<div id="run-analysis-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box modal-box-sm">
        <div class="modal-header modal-header-sm">
            Run Code Risk Analysis
            <button class="modal-close-btn" onclick="closeRunAnalysisModal()">&#10005;</button>
        </div>
        <div class="modal-body modal-body-sm">
            <div id="run-analysis-no-git" style="display:none;">
                <div class="alert alert-warning" style="display:block; margin-top:0;">
                    &#9888; Git Repository URL is not configured for this application.<br>
                    Please set the Git URL in the application settings first.
                </div>
                <button class="btn-secondary" style="margin-top:12px;" onclick="closeRunAnalysisModal()">Close</button>
            </div>
            <div id="run-analysis-form">
                <div class="form-group">
                    <label class="form-label" for="run-analysis-branch">Branch</label>
                    <input type="text" id="run-analysis-branch" class="form-input"
                           placeholder="Leave blank to analyze the default branch" autocomplete="off" />
                </div>
                <button class="btn-danger" id="run-analysis-submit-btn" onclick="submitRunAnalysis()">Run Analysis</button>
                <div class="alert alert-error" id="run-analysis-alert-error"></div>
            </div>
        </div>
    </div>
</div>

<!-- ══ Modal: Analysis Started Info ══ -->
<div id="analysis-started-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box modal-box-sm">
        <div class="modal-header modal-header-sm">
            Code Risk Analysis Started
        </div>
        <div class="modal-body modal-body-sm" style="text-align:center; padding:24px 20px;">
            <p style="margin:0 0 20px; line-height:1.6;">
                Code risk analysis has started.<br>
                Results may take a few minutes.<br>
                You will be notified when the analysis is complete.
            </p>
            <button class="btn-primary" onclick="closeAnalysisStartedModal()">OK</button>
        </div>
    </div>
</div>

<!-- ══ Modal 2: Observability Setup (Loki / Prometheus) ══ -->
<div id="observability-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            Observability Configuration
            <button id="observability-modal-close" class="modal-close-btn" onclick="closeObservabilityModal()" style="display:none;">&#10005;</button>
        </div>
        <div class="modal-body">
            <p class="modal-desc" id="observability-modal-desc">
                Select an observability provider and enter the base URL.
            </p>
            <div class="radio-group" id="observability-provider-group">
                <!-- dynamically populated from OBSERVABILITY_PROVIDERS -->
            </div>
            <div class="form-group">
                <label class="form-label" for="observability-url-input">Base URL</label>
                <input type="text" id="observability-url-input" class="form-input" autocomplete="off" />
            </div>
            <button class="btn-primary" id="observability-save-btn" onclick="saveObservabilityConfig()">Save</button>
            <div class="alert alert-error" id="observability-alert-error"></div>
        </div>
    </div>
</div>

<!-- ── Page Content ── -->
<div class="page-content">

    <!-- 1. System Status (always visible) -->
    <div class="panel">
        <div class="panel-header">System Status</div>
        <table class="info-table">
            <tbody>
                <tr>
                    <td>Environment</td>
                    <td>{{activeProfile}}</td>
                </tr>
                <tr>
                    <td>LLM Provider</td>
                    <td id="status-llm-provider">
                        <div style="display:flex; align-items:center; justify-content:space-between;">
                            <div>
                                {{#configured}}
                                    <img src="/images/{{currentLlm}}.svg" class="provider-logo provider-logo-badge" alt="{{currentLlm}}">
                                    <span class="badge badge-up">{{currentLlm}}</span>
                                    <span style="color:#3c763d; font-weight:600; margin-left:8px;">&#10003; Connected</span>
                                {{/configured}}
                                {{^configured}}
                                    <span style="color:#aaa;">—</span> <span class="badge badge-down">NOT CONFIGURED</span>
                                {{/configured}}
                            </div>
                            {{#configured}}
                                <button class="btn-secondary" style="margin-top:0;" onclick="openLlmModal(true)">Reconfigure</button>
                            {{/configured}}
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>METRIC/LOG Storage</td>
                    <td id="status-observability"><span style="color:#aaa;">—</span></td>
                </tr>
                <tr>
                    <td>GIT Remote</td>
                    <td id="status-git-remote"><span style="color:#aaa;">—</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 2 & 3. Main section — appears with fade-in after both modals are complete -->
    <div id="main-section" class="main-section">

        <!-- 2. Applications (2:8 split) -->
        <div class="app-layout">
            <div class="app-sidebar">
                <div class="panel-header" style="display:flex; align-items:center; justify-content:space-between;">
                    Applications
                    <button class="btn-add" onclick="openAddAppModal()">ADD</button>
                </div>
                <div id="app-list-container">
                    <div class="list-placeholder">Loading...</div>
                </div>
            </div>
            <div class="app-detail" id="app-detail-panel">
                <div class="empty-state">
                    <span>Select an application from the left panel to view details.</span>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="/js/aiops.js"></script>
</body>
</html>
