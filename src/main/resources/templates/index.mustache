<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spring AI Ops</title>
    <link rel="stylesheet" href="/style/aiops.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="/webjars/sockjs-client/1.5.1/sockjs.min.js"></script>
    <script src="/webjars/stomp-websocket/2.3.4/stomp.min.js"></script>
</head>
<body>

<!-- Server-rendered state exposed to JS -->
<script>
const LLM_CONFIGURED      = {{#configured}}true{{/configured}}{{^configured}}false{{/configured}};
const CURRENT_LLM         = '{{currentLlm}}';
const LLM_SELECT_PROVIDER = {{#selectProvider}}true{{/selectProvider}}{{^selectProvider}}false{{/selectProvider}};
</script>

<!-- ── Navbar ── -->
<nav class="navbar">
    <div class="navbar-brand">
        <span class="leaf">&#9752;</span>
        Spring AI Ops
    </div>
    <span class="navbar-subtitle">Grafana Alert &amp; GitHub Code Review Automation</span>
</nav>

<!-- ══ Modal 1: LLM Setup ══ -->
<div id="llm-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            LLM Configuration
            <button id="llm-modal-close" class="modal-close-btn" onclick="closeLlmModal()" style="display:none;">&#10005;</button>
        </div>
        <div class="modal-body">
            <p class="modal-desc" id="llm-modal-desc">
                Select your LLM provider and enter an API key to get started.
            </p>
            <div class="radio-group">
                <div class="radio-option">
                    <input type="radio" name="llm-provider" id="llm-openai" value="openai" checked>
                    <label for="llm-openai">
                        <img src="/images/openai.svg" class="provider-logo" alt="OpenAI">
                        OpenAI
                    </label>
                </div>
                <div class="radio-option">
                    <input type="radio" name="llm-provider" id="llm-anthropic" value="anthropic">
                    <label for="llm-anthropic">
                        <img src="/images/anthropic.svg" class="provider-logo" alt="Anthropic">
                        Anthropic
                    </label>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label" for="llm-api-key">API Key</label>
                <input type="password" id="llm-api-key" class="form-input"
                       placeholder="sk-..." autocomplete="off" />
            </div>
            <button class="btn-primary" id="llm-save-btn" onclick="saveLlmConfig()">
                Save &amp; Connect
            </button>
            <div class="alert alert-success" id="llm-alert-success">
                Connection successful! LLM is ready.
            </div>
            <div class="alert alert-warning" id="llm-alert-warning"></div>
            <div class="alert alert-error"   id="llm-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Select LLM Provider ══ -->
<div id="select-provider-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">Select LLM Provider</div>
        <div class="modal-body">
            <p class="modal-desc">
                API keys are pre-configured in application settings.<br>
                Please select the LLM provider you want to use.
            </p>
            <div class="radio-group">
                <div class="radio-option">
                    <input type="radio" name="select-provider" id="select-openai" value="openai" checked>
                    <label for="select-openai">
                        <img src="/images/openai.svg" class="provider-logo" alt="OpenAI">
                        OpenAI
                    </label>
                </div>
                <div class="radio-option">
                    <input type="radio" name="select-provider" id="select-anthropic" value="anthropic">
                    <label for="select-anthropic">
                        <img src="/images/anthropic.svg" class="provider-logo" alt="Anthropic">
                        Anthropic
                    </label>
                </div>
            </div>
            <button class="btn-primary" id="select-provider-btn" onclick="submitSelectProvider()">Select</button>
            <div class="alert alert-error" id="select-provider-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Add Application ══ -->
<div id="add-app-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            Add Application
            <button class="modal-close-btn" onclick="closeAddAppModal()">&#10005;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label" for="add-app-input">Application Name</label>
                <input type="text" id="add-app-input" class="form-input"
                       placeholder="my-application" autocomplete="off" />
            </div>
            <button class="btn-primary" id="add-app-save-btn" onclick="saveApp()">Add</button>
            <div class="alert alert-success" id="add-app-alert-success">Application registered successfully.</div>
            <div class="alert alert-error"   id="add-app-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal: Confirm Delete Application ══ -->
<div id="confirm-delete-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">Confirm Delete</div>
        <div class="modal-body">
            <p class="modal-desc" id="confirm-delete-desc">Are you sure you want to delete this application?</p>
            <div style="display:flex; gap:10px; margin-top:4px;">
                <button class="btn-primary" onclick="confirmDeleteApp()">Yes</button>
                <button class="btn-secondary" onclick="closeConfirmDeleteModal()">Cancel</button>
            </div>
        </div>
    </div>
</div>

<!-- ══ Modal: GitHub Access Token ══ -->
<div id="github-token-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            GitHub Access Token
            <button class="modal-close-btn" onclick="closeGithubTokenModal()">&#10005;</button>
        </div>
        <div class="modal-body">
            <p class="modal-desc">
                Enter your GitHub Personal Access Token to enable AI Code Review.
                The token requires <code>repo</code> scope to access repository contents.
            </p>
            <div class="form-group">
                <label class="form-label" for="github-token-input">Access Token</label>
                <input type="password" id="github-token-input" class="form-input"
                       placeholder="ghp_..." autocomplete="off" />
            </div>
            <button class="btn-primary" id="github-token-save-btn" onclick="saveGithubToken()">Save</button>
            <div class="alert alert-error" id="github-token-alert-error"></div>
        </div>
    </div>
</div>

<!-- ══ Modal 2: Loki Setup ══ -->
<div id="loki-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">Loki Configuration Required</div>
        <div class="modal-body">
            <p class="modal-desc">
                Loki URL is not configured. Please enter the Loki base URL to enable log analysis.
            </p>
            <div class="form-group">
                <label class="form-label" for="loki-url-input">Loki Base URL</label>
                <input type="text" id="loki-url-input" class="form-input"
                       placeholder="http://loki:3100" autocomplete="off" />
            </div>
            <button class="btn-primary" id="loki-save-btn" onclick="saveLokiUrl()">Save</button>
            <div class="alert alert-error" id="loki-alert-error"></div>
        </div>
    </div>
</div>

<!-- ── Page Content ── -->
<div class="page-content">

    <!-- 1. System Status (always visible) -->
    <div class="panel">
        <div class="panel-header">System Status</div>
        <table class="info-table">
            <tbody>
                <tr>
                    <td>Environment</td>
                    <td>default</td>
                </tr>
                <tr>
                    <td>LLM Provider</td>
                    <td>
                        {{#configured}}
                            <span style="font-weight:600; text-transform:uppercase;">{{currentLlm}}</span> <span class="badge badge-up">UP</span>
                        {{/configured}}
                        {{^configured}}
                            <span style="color:#aaa;">—</span> <span class="badge badge-down">NOT CONFIGURED</span>
                        {{/configured}}
                    </td>
                </tr>
                <tr>
                    <td>Loki URL</td>
                    <td id="status-loki-url"><span style="color:#aaa;">—</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 2 & 3. Main section — appears with fade-in after both modals are complete -->
    <div id="main-section" class="main-section">

        <!-- 2. Applications (2:8 split) -->
        <div class="app-layout">
            <div class="app-sidebar">
                <div class="panel-header" style="display:flex; align-items:center; justify-content:space-between;">
                    Applications
                    <button class="btn-add" onclick="openAddAppModal()">ADD</button>
                </div>
                <div id="app-list-container">
                    <div class="list-placeholder">Loading...</div>
                </div>
            </div>
            <div class="app-detail" id="app-detail-panel">
                <div class="empty-state">
                    <span>Select an application from the left panel to view details.</span>
                </div>
            </div>
        </div>

        <!-- 3. LLM Configuration -->
        <div class="panel">
            <div class="panel-header">LLM Configuration</div>
            <div class="panel-body">
                <table class="info-table" style="margin-bottom:14px;">
                    <tbody>
                        <tr>
                            <td>Provider</td>
                        <td id="llm-config-provider-cell">
                            {{#configured}}
                                <img src="/images/{{currentLlm}}.svg" class="provider-logo provider-logo-badge" alt="{{currentLlm}}">
                                <span class="badge badge-up">{{currentLlm}}</span>
                            {{/configured}}
                        </td>
                        </tr>
                        <tr>
                            <td>Connection</td>
                            <td>
                                <span style="color:#3c763d; font-weight:600;">&#10003; Connected</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <button class="btn-secondary" onclick="openLlmModal(true)">Reconfigure</button>
            </div>
        </div>

    </div>
</div>

<script src="/js/aiops.js"></script>
</body>
</html>
